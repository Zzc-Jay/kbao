{
  "name": "kbao-server",
  "version": "1.0.0",
  "description": "泰和K包游戏服务器",
  "main": "src/index.ts",
  "scripts": {
    "dev": "npm run build:core && ts-node src/index.ts",
    "build:core": "cd ../kbao-core && npx tsc",
    "build": "tsc",
    "start": "npm run build && node dist/index.js",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "express": "^4.21.0",
    "kbao-core": "../kbao-core",
    "socket.io": "^4.7.0",
    "ws": "^8.20.1"
  },
  "devDependencies": {
    "@types/cors": "^2.8.0",
    "@types/express": "^4.17.0",
    "@types/node": "^20.0.0",
    "@types/ws": "^8.18.1",
    "ts-node": "^10.9.0",
    "typescript": "^5.4.0"
  }
}
